              "quickstart",
              "architecture",
              "configuration",
              "deployment-server"
            ]
          },
          {
            "group": "开发与文档站",
            "pages": ["development"]
          }
        ]
      },
      {
        "tab": "API 参考",
        "groups": [
          {
            "group": "概览",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "端点",
            "pages": [
              "api-reference/get-health",
              "api-reference/get-analyze-wallet",
              "api-reference/get-leaderboard"
            ]
          }
        ]
      }
